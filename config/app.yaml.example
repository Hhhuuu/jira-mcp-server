jira:
  # Базовый URL Jira.
  # Для Cloud пример: https://your-domain.atlassian.net
  # Для Server/Data Center пример: https://jira.example.local
  base_url: "https://your-domain.atlassian.net"

  # Версия Jira REST API.
  # Сейчас целимся в read-only сценарии для v2/v3, по умолчанию будет v3.
  api_version: "3"

  # Тип развертывания Jira.
  # Допустимые значения:
  # - cloud
  # - server
  deployment: "cloud"

  # Проверять ли SSL-сертификат.
  verify_ssl: true

  # Локально сохранённые именованные JQL-фильтры.
  # Ими можно управлять через HTTP API или MCP tools.
  filters:
    my_team:
      # Свободное описание фильтра.
      description: "Задачи моей команды"

      # Базовый JQL.
      # Если при вызове будет передан year, сервис добавит ограничение
      # по полю year_field, например created за нужный год.
      jql: 'project = KAN ORDER BY updated DESC'

      # Поле Jira, по которому добавляется ограничение за год.
      year_field: "created"

    my_team_by_year:
      description: "Задачи моей команды за выбранный год"

      # Шаблон JQL с параметрами {year} и {next_year}.
      jql_template: 'project = KAN AND created >= "{year}-01-01" AND created < "{next_year}-01-01" ORDER BY updated DESC'

  # Человекочитаемые алиасы полей Jira.
  # Позволяют не передавать голые customfield_* в API и MCP.
  field_aliases:
    start_date: "customfield_10015"
    team: "customfield_10001"
