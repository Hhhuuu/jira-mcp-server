jira:
  # Тип авторизации.
  # Допустимые значения:
  # - basic
  # - bearer
  auth_type: "basic"

  # Для basic auth обычно используется email или логин.
  username: "you@example.com"

  # Для Jira Cloud API token используется вместе с username в basic auth.
  api_token: "your-atlassian-api-token"

  # Альтернатива для bearer auth.
  # bearer_token: "your-oauth-access-token"

  # Для Jira Cloud OAuth bearer auth нужен cloud_id.
  # cloud_id: "your-cloud-id"
